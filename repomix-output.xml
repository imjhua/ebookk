                        <span className="opacity-0">.</span>
                      </>
                    ) : (
                      <>
                        <span className="opacity-0">.</span>
                        <span className="font-bold font-mono block" style={{ color: '#B5714A' }}>{absolutePageNum}</span>
                      </>
                    )}
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  );
}
