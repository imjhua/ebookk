            style={{ color: '#B4A99E' }}
            onMouseEnter={(e) => (e.currentTarget.style.color = '#B5714A')}
            onMouseLeave={(e) => (e.currentTarget.style.color = '#B4A99E')}
          >
            <RotateCcw size={13} />
            기본값 복원
          </button>
        </div>
      </div>
    </div>
  );
}
