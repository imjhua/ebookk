<file path="src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Serif+KR:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Fira+Code:wght@400;500&display=swap');
@import "tailwindcss";

@theme {
  --font-serif: "Noto Serif KR", "Playfair Display", Georgia, serif;
  --font-sans: "Inter", system-ui, sans-serif;
  --font-mono: "Fira Code", monospace;
  
  --animate-fade-in: fade-in 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  --animate-slide-up: slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;

  /* ── PRESLY Beige Design System ── */
  --color-beige-50:  #FDFAF6;
  --color-beige-100: #F5F0E8;
  --color-beige-200: #E8E0D4;
  --color-beige-300: #D0C4B4;
  --color-warm-dark:   #2A2420;
  --color-warm-dark-2: #3D3530;
  --color-accent:       #B5714A;
  --color-accent-hover: #9E5C38;
  --color-text-primary:   #2A2420;
  --color-text-secondary: #7A6F66;
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { transform: translateY(12px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* Custom Scrollbar */
.scrollbar-thin::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
.scrollbar-thin::-webkit-scrollbar-track {
  background: transparent;
}
.scrollbar-thin::-webkit-scrollbar-thumb {
  background: rgba(42, 36, 32, 0.12);
  border-radius: 9999px;
}
.scrollbar-thin::-webkit-scrollbar-thumb:hover {
  background: rgba(42, 36, 32, 0.22);
}

/* SCREEN-ONLY DEFAULT CUSTOMIZATIONS */
#print-book-surface {
  display: none !important;
}

/* HIGH FIDELITY PRINT MEDIA OVERRIDES WITH DYNAMIC CSS VARIABLES */
:root {
  --print-paper-width: 148mm;
  --print-paper-height: 210mm;
}

@media print {
  @page {
    size: var(--print-paper-width, 148mm) var(--print-paper-height, 210mm) portrait;
    margin: 0;
  }

  /* Force the printer wrapper structure to match the exact page boundaries */
  html, body, #root, #root > div, #print-book-surface {
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    position: static !important;
    background: transparent !important;
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
    overflow: visible !important;
  }

  /* Hide all screen-only UI components */
  .no-print {
    display: none !important;
  }

  /* Create physical page breaks precisely aligned to boundaries */
  .print-sheet {
    display: flex !important;
    flex-direction: column;
    justify-content: space-between;
    width: 100% !important;
    height: 100vh !important;
    max-width: 100% !important;
    max-height: 100vh !important;
    min-width: 100% !important;
    min-height: 100vh !important;
